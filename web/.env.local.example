NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Optional: server-only URL for SSR fetches (e.g. Railway private networking).
# If set, server-api.ts uses this instead of NEXT_PUBLIC_API_URL.
API_INTERNAL_URL=
# Canonical public host (no scheme). Middleware redirects www.<host> -> <host>.
CANONICAL_HOST=bettingwithai.app
# Force https redirects in middleware. Defaults to "1" in production.
FORCE_HTTPS=0
# Public source code URL shown in footer.
NEXT_PUBLIC_SOURCE_URL=https://github.com/marcelr/BettingwithAI
# 32-char hex key for IndexNow (Bing/Yandex/Yep). Leave blank to disable.
INDEXNOW_KEY=
