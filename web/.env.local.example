NEXT_PUBLIC_API_URL=http://localhost:8000
# Production: https://api.bettingwithai.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Production: https://bettingwithai.app
# Optional: server-only URL for SSR fetches (e.g. Railway private networking).
# If set, server-api.ts uses this instead of NEXT_PUBLIC_API_URL.
API_INTERNAL_URL=
# Canonical public host (no scheme). Middleware redirects www.<host> -> <host>.
CANONICAL_HOST=bettingwithai.app
# Force https redirects in middleware. Defaults to "1" in production.
FORCE_HTTPS=0
# Public source code URL shown in footer.
NEXT_PUBLIC_SOURCE_URL=https://github.com/marcelr/BettingwithAI
# 32-char hex key for IndexNow (Bing/Yandex/Yep). Leave blank to disable.
INDEXNOW_KEY=
# Shared secret for POST /api/revalidate (on-demand ISR invalidation from
# the Python scheduler after a snapshot refresh). Leave blank to disable.
REVALIDATE_TOKEN=

# ── Internal owner dashboard (Cloudflare Access / Zero Trust) ─────────
# Hostname dedicated to the owner-only dashboard. The middleware locks
# /admin and /api/admin to this host and 404s them on the public host.
INTERNAL_HOST=ops.bettingwithai.app
# The single allow-listed identity that the upstream Cloudflare Access
# policy is configured to release to the origin.
OWNER_EMAIL=
# Cloudflare Access team domain (no scheme), e.g. acme.cloudflareaccess.com.
# Used to fetch JWKS from https://<team>/cdn-cgi/access/certs.
CF_ACCESS_TEAM_DOMAIN=
# Application AUD tag from the Cloudflare Access self-hosted application.
CF_ACCESS_AUD=
# Local-dev only: when set to "1" alongside NODE_ENV!=production, the
# dashboard accepts the header `x-dev-owner: <email>` instead of a CF JWT.
ALLOW_DEV_OWNER=
# Local-dev only: when set to "1", treats localhost as the internal host.
DEV_INTERNAL=
